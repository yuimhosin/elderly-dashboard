# Streamlit Secrets - 复制为 secrets.toml 并填入真实值
# 格式：每行一个 KEY = "value"，值需用双引号包裹

DEEPSEEK_API_KEY = "sk-your-key"
FEISHU_APP_ID = "cli_xxx"
FEISHU_APP_SECRET = "your_secret"
FEISHU_WEBHOOK_URL = "https://xxx.feishu.cn/flow/api/trigger-webhook/xxx"
# 支持 base 或 wiki 链接，wiki 示例：
FEISHU_BITABLE_URL = "https://tkhome.feishu.cn/wiki/DFIYwb1ELigVNgkdJQAcoPArnRg?table=tblodAIOVXskb6KM"
